{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/Invex.FileSystem/Invex.FileSystem.csproj"
          ]
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "toc.yml",
          "index.md",
          "README.md"
        ]
      },
      {
        "files": [
          "api/**.yml",
          "api/toc.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "docs/toc.yml",
          "docs/**/*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "globalMetadata": {
      "_appTitle": "Invex.FileSystem",
      "_appName": "Invex.FileSystem",
      "_appFooter": "Invex.FileSystem — MIT licensed",
      "_enableSearch": true,
      "_disableContribution": false,
      "_disableToc": false,
      "_gitContribute": {
        "repo": "https://github.com/Invex-Games/filesystem",
        "branch": "main"
      }
    },
    "template": [
      "default",
      "modern"
    ],
    "postProcessors": [],
    "keepFileLink": false,
    "disableGitFeatures": false
  }
}


